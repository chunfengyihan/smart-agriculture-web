# 前端切换为真实接口模式
VITE_DATA_SOURCE=mock
VITE_USE_REMOTE_DATA=false
VITE_DASHBOARD_ENDPOINT=/api/v1/greenhouse/dashboard
VITE_LOCAL_DASHBOARD_PATH=/data/local-dashboard.json

# Django API
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_X_FRAME_OPTIONS=SAMEORIGIN
DJANGO_API_AUTH_REQUIRED=false
DJANGO_API_AUTH_TOKEN=
DJANGO_API_KEY_HEADER=X-API-Key
DJANGO_API_KEY_ALLOWLIST=
DJANGO_API_PUBLIC_PATHS=/api/v1/health/,/api/v1/schema/,/api/v1/docs/,/api/v1/auth/wechat-login,/api/v1/auth/refresh
DJANGO_JWT_ACCESS_TOKEN_MINUTES=30
DJANGO_JWT_REFRESH_TOKEN_DAYS=7

WECHAT_MINIAPP_APPID=
WECHAT_MINIAPP_SECRET=
WECHAT_CODE2SESSION_URL=https://api.weixin.qq.com/sns/jscode2session
WECHAT_CODE2SESSION_TIMEOUT_SECONDS=5
WECHAT_LOGIN_MOCK_ENABLED=false

DB_ENGINE=sqlite
DJANGO_DB_PATH=.runtime/local/db.sqlite3

DJANGO_CACHE_BACKEND=locmem
DJANGO_CACHE_KEY_PREFIX=smart-agri
DJANGO_LOCMEM_CACHE_LOCATION=smart-agri-local
DJANGO_LOCMEM_CACHE_MAX_ENTRIES=512
REDIS_CACHE_URL=redis://127.0.0.1:6379/1

MYSQL_DB_NAME=
MYSQL_DB_USER=
MYSQL_DB_PASSWORD=
MYSQL_DB_HOST=
MYSQL_DB_PORT=3306
MYSQL_CONN_MAX_AGE=60
MYSQL_CHARSET=utf8mb4
MYSQL_OPTIONS_JSON={}
MYSQL_SSL_CA=
MYSQL_SSL_CERT=
MYSQL_SSL_KEY=
MYSQL_TEST_DB_NAME=

EXTERNAL_INTEGRATIONS_ENABLED=false
WEATHER_INTEGRATION_ENABLED=false
WEATHER_FETCH_TIMEOUT_SECONDS=8
WEATHER_CACHE_TTL_SECONDS=21600
WEATHER_FAILURE_CACHE_TTL_SECONDS=60
WEATHER_CACHE_LOCK_SECONDS=30
WEATHER_SOURCE_NAME=Open-Meteo

YOUREN_INTEGRATION_ENABLED=false
YOUREN_FETCH_TIMEOUT_SECONDS=8
YOUREN_TOKEN_TTL_SECONDS=6600
YOUREN_DASHBOARD_DEVICE_PAGE_SIZE=100
YOUREN_MAPPING_PATH=config/greenhouse.mapping.json
# 本地有人云代理服务
API_PORT=8787

# 有人云二次开发密钥，只能放在服务端环境变量中
API_HOST=127.0.0.1
API_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
YOUREN_APP_KEY=your_app_key
YOUREN_APP_SECRET=your_app_secret

DJANGO_API_BASE=http://127.0.0.1:8000
# 如有人云文档或账号环境给出不同路径，可在这里覆盖
YOUREN_API_BASE=
YOUREN_AUTH_PATH=/usrCloud/user/getAuthToken

# AI 作物诊断接口，只能放在服务端环境变量中
AI_PROVIDER=generic_vision
AI_API_KEY=your_ai_api_key
AI_MODEL=gpt-4o-mini
AI_API_BASE=
