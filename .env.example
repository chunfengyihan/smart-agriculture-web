# 前端切换为真实接口模式
VITE_DATA_SOURCE=mock
VITE_USE_REMOTE_DATA=false
VITE_DASHBOARD_ENDPOINT=/api/greenhouse/dashboard
VITE_LOCAL_DASHBOARD_PATH=/data/local-dashboard.json

# Django API
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DB_ENGINE=sqlite
DJANGO_DB_PATH=.runtime/local/db.sqlite3

MYSQL_DB_NAME=
MYSQL_DB_USER=
MYSQL_DB_PASSWORD=
MYSQL_DB_HOST=
MYSQL_DB_PORT=3306
MYSQL_CONN_MAX_AGE=60
MYSQL_CHARSET=utf8mb4
MYSQL_OPTIONS_JSON={}
MYSQL_SSL_CA=
MYSQL_SSL_CERT=
MYSQL_SSL_KEY=
MYSQL_TEST_DB_NAME=

EXTERNAL_INTEGRATIONS_ENABLED=false

# 本地有人云代理服务
API_PORT=8787

# 有人云二次开发密钥，只能放在服务端环境变量中
YOUREN_APP_KEY=your_app_key
YOUREN_APP_SECRET=your_app_secret

# 如有人云文档或账号环境给出不同路径，可在这里覆盖
YOUREN_API_BASE=
YOUREN_AUTH_PATH=/usrCloud/user/getAuthToken

# AI 作物诊断接口，只能放在服务端环境变量中
AI_PROVIDER=generic_vision
AI_API_KEY=your_ai_api_key
AI_MODEL=gpt-4o-mini
AI_API_BASE=
